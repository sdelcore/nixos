{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": ["opencode-plugin-litellm@latest"],
  "enabled_providers": ["litellm", "litellm-responses"],
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "http://llm.ai.tap/v1",
        "apiKey": "{env:LITELLM_API_KEY}"
      }
    }
  }
}
