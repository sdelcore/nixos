#!/usr/bin/env bash
# screen-recorder — toggle wf-recorder: first run records a slurp-selected
# region to ~/Videos; second run stops it. No -e: pgrep returns non-zero when
# not recording (expected), and an escaped slurp should just abort quietly.
set -uo pipefail

VIDEODIR="$HOME/Videos"
DATE_FORMAT="+%Y-%m-%d_%H-%M-%S"

if ! pgrep "wf-recorder" >/dev/null; then
	if [ ! -d "$VIDEODIR" ]; then
		mkdir -p "$VIDEODIR"
	fi
	FILENAME="$VIDEODIR/$(date --utc "$DATE_FORMAT").mp4"
	wf-recorder -f "$FILENAME" -g "$(slurp -c "#FFFFFF")" &>/dev/null &
else
	killall -s SIGINT wf-recorder
fi
